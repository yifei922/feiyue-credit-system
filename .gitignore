# 依赖
node_modules/

# 前端构建产物（部署时由 CI 重新构建）
frontend/dist/

# 本地数据库（运行时生成，含种子数据；部署后由新环境自动初始化）
server/data/

# 日志
*.log

# 本地环境变量（保留 .env.example / .env.server / .env.cloud 等构建配置）
.env
.env.local

# 测试覆盖率报告
coverage/
**/coverage/

# WorkBuddy 内部工作数据（记忆/配置，非项目源码，不应入库）
.workbuddy/
# 例外：项目工作记忆随仓库带走（全新克隆不会被覆盖，仅补充本项目笔记）
!.workbuddy/memory/
!.workbuddy/memory/**

# 运行时数据（本地开发库 / 上传附件 / 测试库），不入库
server/data/
server/src/data/
